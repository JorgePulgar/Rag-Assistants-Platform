# ─────────────────────────────────────────────────────────────────────────────
# Azure AI Foundry (OpenAI-compatible endpoint)
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of your Azure AI Foundry / Azure OpenAI resource.
# Example: https://my-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key for the Azure OpenAI resource (found under "Keys and Endpoint").
AZURE_OPENAI_API_KEY=

# API version to use for all Azure OpenAI calls.
# Keep in sync with the versions supported by your deployments.
AZURE_OPENAI_API_VERSION=2024-10-21

# Name of the chat completion deployment (e.g. gpt-4o-mini or gpt-4o).
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4o-mini

# Name of the text-embedding deployment.
# Must produce 1536-dimensional vectors (text-embedding-3-small).
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ─────────────────────────────────────────────────────────────────────────────
# Azure AI Search
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of your Azure AI Search service.
# Example: https://my-search.search.windows.net
AZURE_SEARCH_ENDPOINT=

# Admin API key for the Azure AI Search service (used for index CRUD + upload).
# Found under Settings > Keys in the Azure Portal.
AZURE_SEARCH_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# SQLAlchemy connection string. Defaults to a local SQLite file.
# For SQLite the path is relative to the directory from which uvicorn is run.
DATABASE_URL=sqlite:///./app.db

# ─────────────────────────────────────────────────────────────────────────────
# RAG pipeline parameters
# ─────────────────────────────────────────────────────────────────────────────

# Target character count per chunk fed to RecursiveCharacterTextSplitter.
CHUNK_SIZE=800

# Character overlap between consecutive chunks to preserve context at boundaries.
CHUNK_OVERLAP=150

# Maximum number of chunks returned per retrieval query (Azure Search top_k).
RETRIEVAL_TOP_K=5

# Minimum semantic reranking score for a chunk to be included in the prompt.
# Chunks below this threshold are discarded; if none pass, the "I don't know"
# path is taken without calling the LLM.
RETRIEVAL_SCORE_THRESHOLD=1.5

# Number of prior conversation messages (user + assistant turns combined)
# included in every LLM call for conversational memory.
HISTORY_MAX_MESSAGES=10

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
